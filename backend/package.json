{
	"name": "backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "pnpm exec biome format --write .",
		"check": "pnpm exec biome check --write .",
		"start": "nest start api",
		"start:dev": "nest start --watch api",
		"start:debug": "nest start --debug --watch api",
		"start:prod": "node dist/apps/api/main",
		"start:local-debug": "NODE_ENV=local pnpm start:debug",
		"lint": "pnpm exec biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:debug": "vitest --inspect-brk --no-file-parallelism",
		"test:e2e": "vitest run --config ./vitest.config.e2e.ts",
		"test:e2e:up": "docker compose -f docker-compose.test.yml up -d",
		"test:e2e:down": "docker compose -f docker-compose.test.yml down",
		"orm": "mikro-orm",
		"orm:update": "NODE_ENV=local mikro-orm schema:update -r",
		"orm:drop": "NODE_ENV=local mikro-orm schema:drop -r",
		"orm:fresh": "NODE_ENV=local mikro-orm schema:fresh -r",
		"migration:create": "pnpm mikro-orm migration:create",
		"migration:up": "pnpm mikro-orm migration:up",
		"migration:list": "pnpm mikro-orm migration:list"
	},
	"dependencies": {
		"@mikro-orm/core": "^7.1.5",
		"@mikro-orm/decorators": "^7.1.5",
		"@mikro-orm/migrations": "^7.1.5",
		"@mikro-orm/nestjs": "^7.0.2",
		"@mikro-orm/postgresql": "^7.1.5",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.0.1",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/swagger": "^11.4.5",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"connect-redis": "^9.0.0",
		"express-session": "^1.19.0",
		"js-yaml": "^5.2.0",
		"nestjs-pino": "^4.6.1",
		"octokit": "^5.0.5",
		"passport": "^0.7.0",
		"passport-github2": "^0.1.12",
		"pg": "^8.22.0",
		"pino-http": "^11.0.0",
