{
	"name": "backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "biome format --write .",
		"start": "nest start api",
		"start:dev": "nest start --watch api",
		"start:debug": "nest start --debug --watch api",
		"start:prod": "node dist/apps/api/main",

		"start:local-debug": "NODE_ENV=local pnpm start:debug",
		"lint": "biome check --write .",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./apps/api/test/jest-e2e.json",
		"orm": "mikro-orm",
		"migration:create": "pnpm mikro-orm migration:create",
		"migration:up": "pnpm mikro-orm migration:up",
		"migration:list": "pnpm mikro-orm migration:list"
	},
	"dependencies": {
		"@mikro-orm/core": "^7.1.5",
		"@mikro-orm/migrations": "^7.1.5",
		"@mikro-orm/nestjs": "^7.0.2",
		"@mikro-orm/postgresql": "^7.1.5",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"js-yaml": "^5.2.0",
		"pg": "^8.22.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@mikro-orm/cli": "^7.1.5",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.0.0",
		"@types/supertest": "^7.0.0",
		"jest": "^30.0.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.22.4",
		"typescript": "^5.7.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node",
		"roots": [
			"<rootDir>/apps/",
			"<rootDir>/libs/"
		],
		"moduleNameMapper": {
			"^@app/environment(|/.*)$": "<rootDir>/libs/environment/src/$1"
		}
	}
}
