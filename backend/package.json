		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@swc/core": "^1.9.3",
		"@types/express": "^5.0.0",
		"@types/express-session": "^1.19.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.0.0",
		"@types/passport-github2": "^1.2.9",
		"@types/supertest": "^7.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"pino-pretty": "^13.1.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-loader": "^9.5.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.22.4",
		"typescript": "^5.7.3",
