{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "apps/api/src",
	"compilerOptions": {
		"deleteOutDir": true,
		"webpack": true,
		"tsConfigPath": "apps/api/tsconfig.app.json"
	},
	"monorepo": true,
	"root": "apps/api",
	"projects": {
		"api": {
			"type": "application",
			"root": "apps/api",
			"entryFile": "main",
			"sourceRoot": "apps/api/src",
			"compilerOptions": {
				"tsConfigPath": "apps/api/tsconfig.app.json"
			}
		},
		"entity": {
			"type": "library",
			"root": "libs/entity",
			"entryFile": "index",
			"sourceRoot": "libs/entity/src",
			"compilerOptions": {
				"tsConfigPath": "libs/entity/tsconfig.lib.json"
			}
		},
		"environment": {
			"type": "library",
			"root": "libs/environment",
			"entryFile": "index",
			"sourceRoot": "libs/environment/src",
			"compilerOptions": {
				"tsConfigPath": "libs/environment/tsconfig.lib.json"
			}
		},
		"logger": {
			"type": "library",
			"root": "libs/logger",
			"entryFile": "index",
			"sourceRoot": "libs/logger/src",
			"compilerOptions": {
				"tsConfigPath": "libs/logger/tsconfig.lib.json"
			}
		}
	}
}
